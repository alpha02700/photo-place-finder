# Copy this file to .streamlit/secrets.toml and fill in your API keys.
# DO NOT commit secrets.toml to GitHub - it is already in .gitignore.
#
# When deploying on Streamlit Community Cloud, paste these values into
# the "Secrets" section of your app settings.

GOOGLE_MAPS_API_KEY = "your_google_maps_api_key_here"
GOOGLE_VISION_API_KEY = "your_google_vision_api_key_here"
